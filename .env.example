# ============================================
# ZIKE BOT - Environment Configuration
# Built by Arsh (escapingdum)
# ============================================

# Discord Bot Token (get from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Groq API Key (get from https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Bot Owner Info
OWNER_ID=1498693593701945374
OWNER_USERNAME=escapingdum
OWNER_NAME=Arsh

# Bot Identity
BOT_NAME=Zike
BOT_PREFIX=@

# Staff Role Configuration
# Set the role ID that can use all bot functions
STAFF_ROLE_ID=your_staff_role_id_here

# AI Configuration
GROQ_MODEL=llama-3.3-70b-versatile
AI_CHAT_CHANNEL_ID=your_ai_chat_channel_id_here

# Whitelisted Users (comma-separated user IDs who can chat with AI in any channel)
AI_WHITELIST=1498693593701945374

# AI Personalities
AI_GENERAL_PERSONALITY=random
AI_CHANNEL_PERSONALITY=focused

# Database
DATA_DIR=./data

# Optional: Webhook for logs
LOG_WEBHOOK_URL=

# Optional: Status message
BOT_STATUS=online
BOT_ACTIVITY_TYPE=WATCHING
BOT_ACTIVITY_TEXT=over the server | @Zike help

# ============================================
# MUSIC - Lavalink Configuration (PUBLIC FREE NODES)
# ============================================
# Uses PUBLIC FREE Lavalink nodes by default. No setup needed!
#
# To use custom nodes, set LAVALINK_NODES in this format:
# name|host|port|password|secure,name2|host2|port2|password2|secure2
#
# Example:
# LAVALINK_NODES=myNode|lavalink.example.com|2333|youshallnotpass|false
#
# Find more free public nodes at:
# - https://lavalink.darrennathanael.com/
# - https://lavalink-list.benoi.fr/
#
# Leave EMPTY to use built-in public nodes (recommended)
LAVALINK_NODES=

# Set to 'false' to disable music entirely (if Lavalink causes issues)
MUSIC_ENABLED=true
