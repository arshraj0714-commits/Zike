# ============================================
# Zike Bot - Docker Ignore
# Files/folders to exclude from Docker build context
# ============================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (use --env-file or env_file in compose)
.env
.env.local
.env.*.local

# Data directory (use volume mount instead)
data/
data/*.json

# Logs
logs/
*.log

# Git
.git/
.gitignore
.gitattributes

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Documentation (not needed at runtime)
README.md
COMMANDS.md
*.md

# Docker files (not needed inside the container)
Dockerfile
docker-compose.yml
.dockerignore

# Railway/other deployment configs
railway.json
Procfile

# Test files
test/
tests/
__tests__/
*.test.js
*.spec.js

# Build artifacts
dist/
build/
.cache/
